# ============================================================
# FacePipe — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your deployment.
# All variables are prefixed with FR_ and grouped by component.

# --- General ---
FR_LOG_LEVEL=INFO
FR_DEBUG=false

# --- Detection ---
FR_DET_SIZE=640
FR_DET_THRESHOLD=0.5

# --- Quality ---
FR_QUALITY_BLUR_THRESHOLD=100.0
FR_QUALITY_MIN_FACE_SIZE=0.015
FR_QUALITY_ENROLLMENT_THRESHOLD=0.65
FR_QUALITY_RECOGNITION_THRESHOLD=0.45

# --- Deepfake ---
FR_DEEPFAKE_ENABLED=true
FR_DEEPFAKE_THRESHOLD=0.5

# --- Anti-Spoofing ---
FR_ANTISPOOF_SECURITY_LEVEL=MEDIUM

# --- Recognition ---
FR_RECOGNITION_MODEL=adaface
FR_RECOGNITION_EMBEDDING_DIM=512
FR_RECOGNITION_MODEL_PATH=         # Leave empty for auto-download
FR_RECOGNITION_TTA_ENABLED=true    # Test-time augmentation (flip averaging)
FR_RECOGNITION_TTA_EXTENDED=false  # Extended TTA: flip + brightness + contrast (4x cost)

# --- Template Aggregation ---
FR_TEMPLATE_STRATEGY=quality_weighted  # quality_weighted | norm_weighted | top_k
FR_TEMPLATE_MIN_FRAMES=3
FR_TEMPLATE_TOP_K=5
FR_TEMPLATE_OUTLIER_SIGMA=1.5      # Adaptive outlier rejection: mean - 1.5*std

# --- Score Normalization ---
FR_NORM_METHOD=z_norm              # z_norm | t_norm | zt_norm | none
FR_NORM_COHORT_SIZE=200

# --- Multi-Model Ensemble ---
FR_ENSEMBLE_ENABLED=false
FR_ENSEMBLE_MODELS=["adaface","arcface"]
FR_ENSEMBLE_FUSION_STRATEGY=score_level  # concat_pca | score_level | quality_gated

# --- Search (FAISS HNSW) ---
FR_HNSW_M=32
FR_HNSW_EF_CONSTRUCTION=200
FR_HNSW_EF_SEARCH=64

# --- Open Set ---
FR_OPENSET_RECOGNITION_THRESHOLD=0.4
FR_OPENSET_MARGIN_THRESHOLD=0.05

# --- Clustering ---
FR_CLUSTER_MIN=2
FR_CLUSTER_MAX=8

# --- Tracking ---
FR_TRACK_BUFFER=30
FR_TRACK_MATCH_THRESHOLD=0.7
FR_TRACK_RE_RECOGNIZE_INTERVAL=30

# --- Active Learning ---
FR_AL_AUTO_ADD_THRESHOLD=0.90
FR_AL_VERIFY_THRESHOLD=0.55
FR_AL_MAX_AUTO_ADDS_PER_HOUR=10

# --- Fusion ---
FR_FUSION_SECURITY_LEVEL=STANDARD  # STANDARD | ELEVATED | MAXIMUM

# --- Security ---
FR_ENCRYPTION_KEY=  # Set to a 32-byte base64-encoded key for production
FR_KEY_PROVIDER=env
FR_IMAGE_RETENTION_HOURS=0

# --- API ---
FR_API_HOST=0.0.0.0
FR_API_PORT=8000
FR_API_WORKERS=4
FR_API_CORS_ORIGINS=["*"]
FR_API_RATE_LIMIT=100

# --- Paths ---
FR_DATA_DIR=./data
FR_MODELS_DIR=./models
FR_LEGACY_DB_DIR=./db

